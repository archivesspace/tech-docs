---
import Default from '@astrojs/starlight/components/PageTitle.astro'
import BlogPostTitle from './BlogPostTitleHeader.astro'
import BlogIndexTitle from './BlogIndexTitleHeader.astro'

const { entry, id } = Astro.locals.starlightRoute
const { title } = entry.data
const data = entry.data

const isBlogIndexPage = id === 'blog'
const isBlogPostPage = id.startsWith('blog/')
const formattedDate =
  isBlogPostPage && data.pubDate
    ? data.pubDate.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      })
    : null
const author = data.authors ? data.authors.join(', ') : null
const datetime = data.pubDate
  ? data.pubDate.toISOString().split('T')[0]
  : null
---

{
  isBlogPostPage ? (
    <BlogPostTitle
      title={title}
      formattedDate={formattedDate}
      datetime={datetime}
      author={author}
    />
  ) : isBlogIndexPage ? (
    <BlogIndexTitle title={title} />
  ) : (
    <Default>
      <slot />
    </Default>
  )
}
