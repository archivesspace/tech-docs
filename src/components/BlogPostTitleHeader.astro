---
import BackToBlog from './BackToBlog.astro'
const { title, formattedDate, datetime, author } = Astro.props
---

<header class="blog-post-header">
  <BackToBlog class="blog-post-header__back" />
  <div class="blog-post-header__meta">
    <time datetime={datetime}>{formattedDate}</time>
    <span aria-hidden="true">·</span>
    <span class="authors">By {author}</span>
  </div>
  <h1 id="_top">{title}</h1>
</header>

<style>
  @layer starlight.core {
    .blog-post-header {
      margin-top: 1rem;
      margin-bottom: 1rem;

      @media (min-width: 50rem) {
        padding-bottom: 1.5rem;
      }
    }

    .blog-post-header .blog-post-header__back {
      margin-bottom: 0.75rem;

      @media (min-width: 50rem) {
        margin-bottom: 1rem;
      }
    }

    .blog-post-header .blog-post-header__meta {
      margin-bottom: 1rem;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
      font-size: 0.9375rem;
      color: var(--sl-color-gray-3);

      time {
        margin-bottom: 0.5rem;

        @media (min-width: 50rem) {
          margin-bottom: 0;
        }
      }

      .authors {
        line-height: 1.4;

        @media (min-width: 50rem) {
          line-height: 1;
        }
      }
    }

    .blog-post-header .blog-post-header__meta span[aria-hidden='true'] {
      display: none;
    }

    .blog-post-header h1 {
      margin-top: 0;
      margin-bottom: 0;
      font-size: var(--sl-text-h1);
      line-height: 1;
      font-weight: 600;
      color: var(--sl-color-white);
    }

    @media (min-width: 50rem) {
      .blog-post-header .blog-post-header__meta {
        flex-direction: row;
        align-items: center;
        gap: 0.375rem;
        font-size: 1rem;
        margin-bottom: 1rem;
      }

      .blog-post-header .blog-post-header__meta span[aria-hidden='true'] {
        display: inline;
      }
    }
  }
</style>
